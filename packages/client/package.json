{
  "name": "@kevincii/http-query-client",
  "version": "0.3.0",
  "description": "Batteries-included TypeScript client for the HTTP QUERY method: type-safe queries, nested filters, fallbacks, retries, timeout, caching, pagination. Browser + Node.",
  "license": "MIT",
  "author": {
    "name": "Kevin Imig",
    "url": "https://github.com/Kevinci/http-query"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Kevinci/http-query.git",
    "directory": "packages/client"
  },
  "homepage": "https://github.com/Kevinci/http-query/tree/main/packages/client#readme",
  "keywords": [
    "http",
    "query",
    "fetch",
    "client",
    "typescript",
    "request",
    "fallback",
    "retry",
    "filter",
    "pagination"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepare:ghpages": "node ./scripts/prepare-ghpages.cjs",
    "dev": "node ./scripts/dev-server.cjs",
    "mock-server": "node ./scripts/mock-server.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "@kevincii/http-query-core": "^0.3.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
